APP_NAME="BlogFuel"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

# Unused unless you switch cache/queue/session to Memcached or Redis.
# MEMCACHED_HOST=127.0.0.1
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

MAIL_MAILER=failover
MAIL_SCHEME=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_REPLY_TO_ADDRESS="support@example.com"
MAIL_REPLY_TO_NAME="${APP_NAME}"

# Unused unless you switch file storage to Amazon S3 or another AWS-backed service.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT=90

RECAPTCHA_ENTERPRISE_ENABLED=false
RECAPTCHA_ENTERPRISE_SITE_KEY=
RECAPTCHA_ENTERPRISE_API_KEY=
RECAPTCHA_ENTERPRISE_PROJECT_ID=
RECAPTCHA_ENTERPRISE_BASE_URL=https://recaptchaenterprise.googleapis.com/v1
RECAPTCHA_ENTERPRISE_MIN_SCORE=0.5
RECAPTCHA_ENTERPRISE_TIMEOUT=10

BLOGFUEL_FREE_GENERATIONS=5
BLOGFUEL_GUEST_FREE_GENERATIONS=1
BLOGFUEL_ADMIN_EMAIL=admin@example.com
BLOGFUEL_ADMIN_PASSWORD=change-me-admin-password
BLOGFUEL_DEPLOYMENT_ENABLED=false
BLOGFUEL_DEPLOYMENT_TOKEN=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
STRIPE_PRICE_PACK_25=
STRIPE_PRICE_PACK_100=
STRIPE_MONTHLY_PRICE_LABEL="£19 / month"
STRIPE_ANNUAL_PRICE_LABEL="£190 / year"
STRIPE_PACK_25_PRICE_LABEL="£12 one-off"
STRIPE_PACK_100_PRICE_LABEL="£39 one-off"
STRIPE_ANNUAL_BADGE="Best overall value"
STRIPE_PACK_100_BADGE="Best pack value"

VITE_APP_NAME="${APP_NAME}"
